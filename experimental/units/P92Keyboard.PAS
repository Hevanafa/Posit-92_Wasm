implementation

{$ifdef P92_SDL2}
function IsKeyDown(const scancode: integer): boolean;
begin
  isKeyDown := keyState[scancode]
end;

function SDLToDOSScancode(const scancode: integer): integer;
begin
  SDLToDOSScancode := 0;

  if (scancode in [SDL_SCANCODE_A..SDL_SCANCODE_Z]) then begin
    case scancode of
      SDL_SCANCODE_Q: SDLToDOSScancode := SC_Q;
      SDL_SCANCODE_W: SDLToDOSScancode := SC_W;
      SDL_SCANCODE_E: SDLToDOSScancode := SC_E;
      SDL_SCANCODE_R: SDLToDOSScancode := SC_R;
      SDL_SCANCODE_T: SDLToDOSScancode := SC_T;
      SDL_SCANCODE_Y: SDLToDOSScancode := SC_Y;
      SDL_SCANCODE_U: SDLToDOSScancode := SC_U;
      SDL_SCANCODE_I: SDLToDOSScancode := SC_I;
      SDL_SCANCODE_O: SDLToDOSScancode := SC_O;
      SDL_SCANCODE_P: SDLToDOSScancode := SC_P;

      SDL_SCANCODE_A: SDLToDOSScancode := SC_A;
      SDL_SCANCODE_S: SDLToDOSScancode := SC_S;
      SDL_SCANCODE_D: SDLToDOSScancode := SC_D;
      SDL_SCANCODE_F: SDLToDOSScancode := SC_F;
      SDL_SCANCODE_G: SDLToDOSScancode := SC_G;
      SDL_SCANCODE_H: SDLToDOSScancode := SC_H;
      SDL_SCANCODE_J: SDLToDOSScancode := SC_J;
      SDL_SCANCODE_K: SDLToDOSScancode := SC_K;
      SDL_SCANCODE_L: SDLToDOSScancode := SC_L;

      SDL_SCANCODE_Z: SDLToDOSScancode := SC_Z;
      SDL_SCANCODE_X: SDLToDOSScancode := SC_X;
      SDL_SCANCODE_C: SDLToDOSScancode := SC_C;
      SDL_SCANCODE_V: SDLToDOSScancode := SC_V;
      SDL_SCANCODE_B: SDLToDOSScancode := SC_B;
      SDL_SCANCODE_N: SDLToDOSScancode := SC_N;
      SDL_SCANCODE_M: SDLToDOSScancode := SC_M;
    end;
    exit
  end;

  if (scancode in [SDL_SCANCODE_1..SDL_SCANCODE_0]) then begin
    SDLToDOSScancode := scancode - (SDL_SCANCODE_1 - SC_1);
    exit
  end;

  { TODO: Numpad keys }

  case scancode of
    SDL_SCANCODE_MINUS:
      SDLToDOSScancode := SC_MINUS;
    SDL_SCANCODE_EQUALS:
      SDLToDOSScancode := SC_EQUALS;
    SDL_SCANCODE_LEFTBRACKET:
      SDLToDOSScancode := SC_LEFT_BRACKET;
    SDL_SCANCODE_RIGHTBRACKET:
      SDLToDOSScancode := SC_RIGHT_BRACKET;

    SDL_SCANCODE_BACKSLASH:
      SDLToDOSScancode := SC_BACKSLASH;
    SDL_SCANCODE_SEMICOLON:
      SDLToDOSScancode := SC_SEMICOLON;
    SDL_SCANCODE_APOSTROPHE:
      SDLToDOSScancode := SC_APOSTROPHE;
    SDL_SCANCODE_GRAVE:
      SDLToDOSScancode := SC_BACKQUOTE;

    SDL_SCANCODE_COMMA:
      SDLToDOSScancode := SC_COMMA;
    SDL_SCANCODE_PERIOD:
      SDLToDOSScancode := SC_PERIOD;
    SDL_SCANCODE_SLASH:
      SDLToDOSScancode := SC_SLASH;
    SDL_SCANCODE_TAB:
      SDLToDOSScancode := SC_TAB;

    SDL_SCANCODE_BACKSPACE:
      SDLToDOSScancode := SC_BACKSPACE;
    SDL_SCANCODE_RETURN:
      SDLToDOSScancode := SC_ENTER;
    SDL_SCANCODE_ESCAPE:
      SDLToDOSScancode := SC_ESCAPE;
    SDL_SCANCODE_SPACE:
      SDLToDOSScancode := SC_SPACE;

    SDL_SCANCODE_LSHIFT:
      SDLToDOSScancode := SC_LEFT_SHIFT;
    SDL_SCANCODE_RSHIFT:
      SDLToDOSScancode := SC_RIGHT_SHIFT;
    SDL_SCANCODE_LCTRL:
      SDLToDOSScancode := SC_LEFT_CONTROL;
    SDL_SCANCODE_LALT:
      SDLToDOSScancode := SC_LEFT_ALT;

    SDL_SCANCODE_F1:
      SDLToDOSScancode := SC_F1;
    SDL_SCANCODE_F2:
      SDLToDOSScancode := SC_F2;
    SDL_SCANCODE_F3:
      SDLToDOSScancode := SC_F3;
    SDL_SCANCODE_F4:
      SDLToDOSScancode := SC_F4;
    SDL_SCANCODE_F5:
      SDLToDOSScancode := SC_F5;
    SDL_SCANCODE_F6:
